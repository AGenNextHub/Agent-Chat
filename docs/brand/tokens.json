{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "AGenNext Chat canonical design tokens (W3C DTCG format). Single source of truth; tokens.css is a generated export. Do not edit derived files by hand.",
  "color": {
    "indigo": {
      "700": { "$type": "color", "$value": "#3730A3" },
      "600": { "$type": "color", "$value": "#4338CA" },
      "500": { "$type": "color", "$value": "#6366F1" },
      "100": { "$type": "color", "$value": "#E7E5FA" }
    },
    "cyan": {
      "400": { "$type": "color", "$value": "#22C3D6" },
      "300": { "$type": "color", "$value": "#67E8F9" }
    },
    "slate": {
      "950": { "$type": "color", "$value": "#15132A" },
      "900": { "$type": "color", "$value": "#16142E" },
      "700": { "$type": "color", "$value": "#3A3852" },
      "500": { "$type": "color", "$value": "#6A6982" },
      "300": { "$type": "color", "$value": "#D8D6E4" },
      "100": { "$type": "color", "$value": "#EFEEF6" },
      "50":  { "$type": "color", "$value": "#F7F6FB" }
    },
    "rose":  { "600": { "$type": "color", "$value": "#DA2A55" } },
    "amber": { "500": { "$type": "color", "$value": "#E6960F" } },
    "emerald": { "500": { "$type": "color", "$value": "#0FA577" } },
    "white": { "$type": "color", "$value": "#FFFFFF" }
  },
  "semantic": {
    "bg":            { "$type": "color", "$value": "{color.slate.50}" },
    "surface":       { "$type": "color", "$value": "{color.white}" },
    "surfaceRaised": { "$type": "color", "$value": "{color.slate.100}" },
    "text":          { "$type": "color", "$value": "{color.slate.950}" },
    "textMuted":     { "$type": "color", "$value": "{color.slate.500}" },
    "primary":       { "$type": "color", "$value": "{color.indigo.600}" },
    "primaryHover":  { "$type": "color", "$value": "{color.indigo.700}" },
    "onPrimary":     { "$type": "color", "$value": "{color.white}" },
    "accent":        { "$type": "color", "$value": "{color.cyan.400}" },
    "link":          { "$type": "color", "$value": "{color.indigo.600}" },
    "border":        { "$type": "color", "$value": "{color.slate.300}" },
    "focusRing":     { "$type": "color", "$value": "{color.cyan.400}" },
    "danger":        { "$type": "color", "$value": "{color.rose.600}" },
    "warning":       { "$type": "color", "$value": "{color.amber.500}" },
    "success":       { "$type": "color", "$value": "{color.emerald.500}" }
  },
  "font": {
    "sans": { "$type": "fontFamily", "$value": ["Inter", "system-ui", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
  },
  "fontSize": {
    "xs":   { "$type": "dimension", "$value": "12px" },
    "sm":   { "$type": "dimension", "$value": "14px" },
    "base": { "$type": "dimension", "$value": "16px" },
    "lg":   { "$type": "dimension", "$value": "18px" },
    "xl":   { "$type": "dimension", "$value": "20px" },
    "2xl":  { "$type": "dimension", "$value": "24px" },
    "3xl":  { "$type": "dimension", "$value": "30px" },
    "display": { "$type": "dimension", "$value": "36px" }
  },
  "fontWeight": {
    "regular":  { "$type": "fontWeight", "$value": 400 },
    "medium":   { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold":     { "$type": "fontWeight", "$value": 700 }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "16px" },
    "pill": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px rgba(11,16,32,0.06)" },
    "md": { "$type": "shadow", "$value": "0 4px 12px rgba(11,16,32,0.10)" },
    "lg": { "$type": "shadow", "$value": "0 12px 32px rgba(11,16,32,0.16)" }
  },
  "motion": {
    "fast":     { "$type": "duration", "$value": "120ms" },
    "base":     { "$type": "duration", "$value": "200ms" },
    "slow":     { "$type": "duration", "$value": "320ms" },
    "easing":   { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] }
  }
}
